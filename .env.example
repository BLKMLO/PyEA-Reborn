# Copier ce fichier en `.env` et remplir les valeurs réelles.
# `.env` est ignoré par git : les secrets ne doivent JAMAIS être commités.

# --- Interactive Brokers (TWS ou IB Gateway) ---
IB_HOST=127.0.0.1
# Ports par défaut TWS : 7497 = paper trading, 7496 = live.
# (IB Gateway : 4002 = paper, 4001 = live.)
IB_PORT_PAPER=7497
IB_PORT_LIVE=7496
IB_CLIENT_ID=1
IB_ACCOUNT_ID=

# --- MetaTrader 5 (terminal MT5) ---
# PyEA s'attache à un terminal MT5 DÉJÀ lancé et connecté à un compte : aucun
# identifiant ici (le compte, démo ou réel, se choisit dans le terminal).
# Chemin OPTIONNEL vers terminal64.exe pour lancer le bon terminal s'il n'est
# pas déjà ouvert ; laissé vide = détection automatique.
# MT5_TERMINAL_PATH=

# --- Serveur web (surcharge optionnelle de config.yaml) ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
